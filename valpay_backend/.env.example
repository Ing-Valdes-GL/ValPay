APP_NAME=ValPay
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Douala

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=db.supabase.co
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=postgres
DB_PASSWORD=your_supabase_password
DB_SCHEMA=public

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# CamPay
CAMPAY_APP_USERNAME=
CAMPAY_APP_PASSWORD=
CAMPAY_BASE_URL=https://demo.campay.net/api
CAMPAY_WEBHOOK_SECRET=
CAMPAY_REDIRECT_URL=${APP_URL}/api/v1/payments/campay/return

# Reloadly
RELOADLY_CLIENT_ID=
RELOADLY_CLIENT_SECRET=
RELOADLY_BASE_URL=https://topups.reloadly.com
RELOADLY_AUTH_URL=https://auth.reloadly.com

# Cache
CACHE_STORE=file
CACHE_PREFIX=valpay_
QUEUE_CONNECTION=database

# Session
SESSION_DRIVER=cookie
SESSION_LIFETIME=120

# Mail (optionnel)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@valpay.cm
MAIL_FROM_NAME="${APP_NAME}"

# Frontend URL (pour CORS)
FRONTEND_URL=http://localhost:3000
MOBILE_APP_URL=valpay://

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,valpay.cm
